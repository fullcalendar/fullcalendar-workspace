{
  "name": "@fullcalendar/moment",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Moment Plugin",
  "description": "Enhanced date formatting and conversion with Moment",
  "keywords": [
    "moment"
  ],
  "homepage": "https://fullcalendar.io/docs/moment-plugin",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@fullcalendar/core-types": "workspace:7.0.0-beta.6",
    "@fullcalendar/core": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "moment": "^2.29.1"
  },
  "devDependencies": {
    "@fullcalendar-scripts/standard": "workspace:*",
    "moment": "^2.29.1"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.Moment"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.Moment"
      }
    },
    "dependencyGlobalVars": {
      "moment": "moment"
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

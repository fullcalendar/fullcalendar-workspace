{
  "name": "@fullcalendar/bootstrap5",
  "version": "7.0.0",
  "title": "FullCalendar Bootstrap 5 Plugin",
  "description": "Bootstrap 5 compatibility theme for FullCalendar",
  "keywords": [
    "bootstrap",
    "bootstrap5"
  ],
  "homepage": "https://fullcalendar.io/docs/bootstrap5",
  "peerDependencies": {
    "@fullcalendar/core": "workspace:7.0.0",
    "bootstrap": ">=5.3.0 <6.0.0",
    "bootstrap-icons": "^1.8.0"
  },
  "devDependencies": {
    "@fullcalendar/core": "workspace:7.0.0",
    "@fullcalendar-scripts/standard": "workspace:*",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "themeName": "bootstrap5",
    "globalConfig": {
    },
    "exports": {
      ".": {
        "format": "module"
      },
      "./global": {
        "format": "global",
        "primary": true
      },
      "./theme.css": {
        "format": "css",
        "primary": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

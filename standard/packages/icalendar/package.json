{
  "name": "@fullcalendar/icalendar",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar iCalendar Plugin",
  "description": "Display events from a public iCalendar feed",
  "keywords": [
    "icalendar",
    "ics"
  ],
  "homepage": "https://fullcalendar.io/docs/icalendar",
  "peerDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "ical.js": "^2.0.0"
  },
  "devDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*",
    "ical.js": "^2.0.0"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.ICalendar"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.ICalendar"
      }
    },
    "dependencyGlobalVars": {
      "ical.js": "ICAL"
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

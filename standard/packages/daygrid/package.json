{
  "name": "@fullcalendar/daygrid",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Day Grid Plugin",
  "description": "Display events on a month view or \"day grid\" view",
  "homepage": "https://fullcalendar.io/docs/month-view",
  "keywords": [
    "month",
    "month-view"
  ],
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.DayGrid"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.DayGrid"
      },
      "./internal": {
        "module": true,
        "globalVar": "FullCalendar.DayGrid.Internal"
      }
    },
    "dependencyGlobalVars": {
      "preact": "",
      "preact/compat": "",
      "react": "",
      "react-dom": "",
      "react-dom/client": ""
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

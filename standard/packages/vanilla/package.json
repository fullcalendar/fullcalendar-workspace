{
  "name": "@fullcalendar/vanilla",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@fullcalendar/preact": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar-scripts/standard": "workspace:*",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar",
        "css": true
      },
      "./all": {
        "module": true,
        "globalVar": "FullCalendar"
      },
      "./all.global": {
        "iife": true,
        "globalVar": "FullCalendar"
      },
      "./locales-all": {
        "generator": "./scripts/generate-locales-all.ts",
        "module": true
      },
      "./locales/*": {
        "generator": "./scripts/generate-locales.ts",
        "types": "locales/locale",
        "module": true
      },
      "./interaction": {
        "module": true
      },
      "./daygrid": {
        "module": true
      },
      "./timegrid": {
        "module": true
      },
      "./multimonth": {
        "module": true
      },
      "./list": {
        "module": true
      }
    },
    "dependencyGlobalVars": {
      "@fullcalendar/preact": "",
      "@fullcalendar/preact/internal": "",
      "preact": "",
      "preact/compat": "",
      "react": "",
      "react-dom": "",
      "react-dom/client": ""
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

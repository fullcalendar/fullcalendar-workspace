{
  "name": "@fullcalendar/vanilla",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@fullcalendar/preact": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar-scripts/standard": "workspace:*",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build && pnpm run dist-prune",
    "dist-prune": "rm -rf ./dist/skeleton.js ./dist/themes/*/theme.js ./dist/themes/*/palette.js ./dist/themes/*/palettes/*.js",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true
      },
      "./all": {
        "module": true,
        "sideEffects": true
      },
      "./all.global": {
        "global": "FullCalendar"
      },
      "./skeleton": {
        "cssExtract": true
      },
      "./internal": {
        "module": true
      },
      "./internal-classnames": {
        "module": true
      },
      "./locales-all": {
        "generator": "./scripts/generate-locales-all.ts",
        "module": true
      },
      "./locales/*": {
        "generator": "./scripts/generate-locales.ts",
        "types": "locales/locale",
        "module": true
      },
      "./interaction": {
        "module": true
      },
      "./daygrid": {
        "module": true
      },
      "./timegrid": {
        "module": true
      },
      "./multimonth": {
        "module": true
      },
      "./list": {
        "module": true
      },
      "./themes/classic": {
        "src": "themes/classic/index",
        "module": true
      },
      "./themes/classic/global": {
        "external": [
          "react",
          "react-dom",
          "@fullcalendar/preact",
          "@fullcalendar/preact/internal"
        ],
        "globals": {
          "@fullcalendar/preact": "FullCalendar.Preact",
          "react/jsx-runtime": "FullCalendar.JSXRuntime"
        }
      },
      "./themes/classic/theme": {
        "cssExtract": true
      },
      "./themes/classic/palette": {
        "cssExtract": true
      },
      "./themes/monarch": {
        "src": "themes/monarch/index",
        "module": true
      },
      "./themes/monarch/global": {
        "iife": true,
        "external": [
          "react",
          "react-dom",
          "@fullcalendar/preact"
        ],
        "globals": {
          "@fullcalendar/preact": "FullCalendar.Preact",
          "react/jsx-runtime": "FullCalendar.JSXRuntime"
        }
      },
      "./themes/monarch/theme": {
        "cssExtract": true
      },
      "./themes/monarch/palettes/*": {
        "cssExtract": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

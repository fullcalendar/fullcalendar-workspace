{
  "name": "@fullcalendar/vanilla",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@fullcalendar/preact": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar-scripts/standard": "workspace:*",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "globalConfig": {
      "primaryGlobal": "FullCalendar",
      "sharedProp": "Shared"
    },
    "exports": {
      ".": {
        "format": "module"
      },
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./all.global": {
        "format": "global",
        "primary": true
      },
      "./skeleton.css": {
        "format": "css",
        "import": "@fullcalendar/preact/skeleton.css"
      },
      "./internal": {
        "format": "module"
      },
      "./internal-classnames": {
        "format": "module"
      },
      "./locales-all": {
        "format": "module",
        "generator": "./scripts/generate-locales-all.ts"
      },
      "./locales/*": {
        "format": "module",
        "generator": "./scripts/generate-locales.ts",
        "types": "locales/locale"
      },
      "./interaction": {
        "format": "module"
      },
      "./daygrid": {
        "format": "module"
      },
      "./timegrid": {
        "format": "module"
      },
      "./multimonth": {
        "format": "module"
      },
      "./list": {
        "format": "module"
      },
      "./themes/classic": {
        "format": "module",
        "src": "themes/classic/index"
      },
      "./themes/classic/global": {
        "format": "global"
      },
      "./themes/classic/theme.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/classic/theme.css"
      },
      "./themes/classic/palette.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/classic/palette.css"
      },
      "./themes/monarch": {
        "format": "module",
        "src": "themes/monarch/index"
      },
      "./themes/monarch/global": {
        "format": "global"
      },
      "./themes/monarch/theme.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/monarch/theme.css"
      },
      "./themes/monarch/palettes/blue.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/monarch/palettes/blue.css"
      },
      "./themes/monarch/palettes/green.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/monarch/palettes/green.css"
      },
      "./themes/monarch/palettes/purple.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/monarch/palettes/purple.css"
      },
      "./themes/monarch/palettes/red.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/monarch/palettes/red.css"
      },
      "./themes/monarch/palettes/yellow.css": {
        "format": "css",
        "import": "@fullcalendar/preact/themes/monarch/palettes/yellow.css"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/preact",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar-scripts/standard": "workspace:*",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar"
      },
      "./internal": {
        "module": true,
        "globalVar": "FullCalendar.Internal"
      },
      "./internal-classnames": {
        "module": true,
        "globalVar": "FullCalendar.InternalClassNames"
      },
      "./locales-all": {
        "generator": "./scripts/generate-locales-all.ts",
        "module": true
      },
      "./locales/*": {
        "module": true
      }
    },
    "dependencyGlobalVars": {
      "preact": "",
      "preact/compat": "",
      "react": "",
      "react-dom": "",
      "react-dom/client": ""
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

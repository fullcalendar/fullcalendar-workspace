{
  "name": "@fullcalendar/preact",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar/timeline": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-daygrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-timegrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-timeline": "workspace:7.0.0-beta.6",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "moduleConfig": {
      "cssExtract": "skeleton.css"
    },
    "exports": {
      ".": {
        "format": "module"
      },
      "./all": {
        "format": "module"
      },
      "./public-components": {
        "format": "module"
      },
      "./public-api": {
        "format": "module"
      },
      "./protected-api": {
        "format": "module"
      },
      "./protected-styles": {
        "format": "module"
      },
      "./locales-all": {
        "format": "module",
        "generator": "./scripts/generate-locales-all.ts"
      },
      "./locales/*": {
        "format": "module"
      },
      "./interaction": {
        "format": "module"
      },
      "./daygrid": {
        "format": "module"
      },
      "./timegrid": {
        "format": "module"
      },
      "./multimonth": {
        "format": "module"
      },
      "./list": {
        "format": "module"
      },
      "./themes/classic": {
        "format": "module",
        "src": "themes/classic/index"
      },
      "./themes/classic/theme.css": {
        "format": "css"
      },
      "./themes/classic/palette.css": {
        "format": "css"
      },
      "./themes/monarch": {
        "format": "module",
        "src": "themes/monarch/index"
      },
      "./themes/monarch/theme.css": {
        "format": "css"
      },
      "./themes/monarch/palettes/blue.css": {
        "format": "css"
      },
      "./themes/monarch/palettes/green.css": {
        "format": "css"
      },
      "./themes/monarch/palettes/purple.css": {
        "format": "css"
      },
      "./themes/monarch/palettes/red.css": {
        "format": "css"
      },
      "./themes/monarch/palettes/yellow.css": {
        "format": "css"
      },
      "./themes/breezy": {
        "format": "module",
        "src": "themes/breezy/index"
      },
      "./themes/breezy/theme.css": {
        "format": "css"
      },
      "./themes/breezy/palettes/emerald.css": {
        "format": "css"
      },
      "./themes/breezy/palettes/honey.css": {
        "format": "css"
      },
      "./themes/breezy/palettes/indigo.css": {
        "format": "css"
      },
      "./themes/breezy/palettes/rose.css": {
        "format": "css"
      },
      "./themes/forma": {
        "format": "module",
        "src": "themes/forma/index"
      },
      "./themes/forma/theme.css": {
        "format": "css"
      },
      "./themes/forma/palettes/blue.css": {
        "format": "css"
      },
      "./themes/forma/palettes/green.css": {
        "format": "css"
      },
      "./themes/forma/palettes/purple.css": {
        "format": "css"
      },
      "./themes/forma/palettes/red.css": {
        "format": "css"
      },
      "./themes/pulse": {
        "format": "module",
        "src": "themes/pulse/index"
      },
      "./themes/pulse/theme.css": {
        "format": "css"
      },
      "./themes/pulse/palettes/blue.css": {
        "format": "css"
      },
      "./themes/pulse/palettes/green.css": {
        "format": "css"
      },
      "./themes/pulse/palettes/purple.css": {
        "format": "css"
      },
      "./themes/pulse/palettes/red.css": {
        "format": "css"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/preact",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@fullcalendar/timeline": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-daygrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-timegrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-timeline": "workspace:7.0.0-beta.6",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build && pnpm run dist-prune",
    "dist-prune": "rm -rf ./dist/skeleton.js ./dist/themes/*/theme.js ./dist/themes/*/palette.js ./dist/themes/*/palettes/*.js",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true
      },
      "./all": {
        "module": true,
        "sideEffects": true
      },
      "./skeleton": {
        "cssExtract": true
      },
      "./internal": {
        "module": true
      },
      "./internal-classnames": {
        "module": true
      },
      "./locales-all": {
        "generator": "./scripts/generate-locales-all.ts",
        "module": true
      },
      "./locales/*": {
        "module": true
      },
      "./interaction": {
        "module": true
      },
      "./daygrid": {
        "module": true
      },
      "./timegrid": {
        "module": true
      },
      "./multimonth": {
        "module": true
      },
      "./list": {
        "module": true
      },
      "./themes/classic": {
        "src": "themes/classic/index",
        "module": true
      },
      "./themes/classic/theme": {
        "cssExtract": true
      },
      "./themes/classic/palette": {
        "cssExtract": true
      },
      "./themes/monarch": {
        "src": "themes/monarch/index",
        "module": true
      },
      "./themes/monarch/theme": {
        "cssExtract": true
      },
      "./themes/monarch/palettes/blue": {
        "cssExtract": true
      },
      "./themes/monarch/palettes/green": {
        "cssExtract": true
      },
      "./themes/monarch/palettes/purple": {
        "cssExtract": true
      },
      "./themes/monarch/palettes/red": {
        "cssExtract": true
      },
      "./themes/monarch/palettes/yellow": {
        "cssExtract": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

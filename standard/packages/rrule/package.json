{
  "name": "@fullcalendar/rrule",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar RRule Plugin",
  "description": "Recurring events with RRule",
  "keywords": [
    "rrule"
  ],
  "homepage": "https://fullcalendar.io/docs/rrule-plugin",
  "peerDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "rrule": "^2.6.0"
  },
  "devDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*",
    "rrule": "^2.6.0"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.RRule"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.RRule"
      }
    },
    "dependencyGlobalVars": {
      "rrule": "rrule"
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/lwc-example",
  "private": true,
  "version": "7.0.0",
  "description": "Salesforce smoke test app for FullCalendar LWC",
  "type": "module",
  "scripts": {
    "dep:build": "cd ../lwc && pnpm build && cd - && ./scripts/build-metadata.ts",
    "smoke:login": "sf org login web --set-default --alias fullcalendar-dev",
    "smoke:orgs": "sf org list",
    "smoke:deploy": "sf project deploy start --source-dir force-app --target-org fullcalendar-dev"
  },
  "devDependencies": {
    "@fullcalendar/lwc": "workspace:7.0.0",
    "@salesforce/cli": "^2.112.6",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.3"
  }
}

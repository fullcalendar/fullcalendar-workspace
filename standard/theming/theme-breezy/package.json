{
  "name": "@fullcalendar/theme-breezy",
  "version": "7.0.0-beta.6",
  "peerDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar/timeline": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-daygrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-timegrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource-timeline": "workspace:7.0.0-beta.6",
    "@fullcalendar/adaptive": "workspace:7.0.0-beta.6",
    "@fullcalendar/scrollgrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/list": "workspace:7.0.0-beta.6",
    "@fullcalendar/multimonth": "workspace:7.0.0-beta.6"
  },
  "scripts": {
    "build": "standard-scripts pkg:build && pnpm run clean-dist",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint .",
    "clean-dist": "rm -f dist/palettes/*.js dist/palettes/*.min.js"
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.ThemeBreezy"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.ThemeBreezy",
        "css": true
      },
      "./palettes/emerald": {
        "iife": true,
        "css": true
      },
      "./palettes/honey": {
        "iife": true,
        "css": true
      },
      "./palettes/indigo": {
        "iife": true,
        "css": true
      },
      "./palettes/rose": {
        "iife": true,
        "css": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

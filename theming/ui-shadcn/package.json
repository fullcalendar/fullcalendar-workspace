{
  "private": true,
  "name": "@fullcalendar/ui-shadcn",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc && pnpm run build:registry",
    "build:registry": "node ./scripts/build-registry-items.ts",
    "dev": "tsc --watch",
    "serve": "serve registry-dist",
    "clean": "rm -rf dist tsconfig.tsbuildinfo registry-dist",
    "cloudflare": "wrangler deploy"
  },
  "exports": {
    "./package.json": "./package.json",
    "./demo-palettes.css": "./src/demo-palettes.css",
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "peerDependencies": {
    "@fullcalendar/react": "workspace:*",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@fullcalendar/react": "workspace:*",
    "@fullcalendar/react-scheduler": "workspace:*",
    "@fullcalendar/theme-breezy-tailwind": "workspace:*",
    "@fullcalendar/theme-classic-tailwind": "workspace:*",
    "@fullcalendar/theme-common": "workspace:*",
    "@fullcalendar/theme-forma-tailwind": "workspace:*",
    "@fullcalendar/theme-monarch-tailwind": "workspace:*",
    "@fullcalendar/theme-pulse-tailwind": "workspace:*",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "serve": "^14.2.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.7.2",
    "wrangler": "^4.54.0",
    "temporal-polyfill": "^0.3.2"
  }
}

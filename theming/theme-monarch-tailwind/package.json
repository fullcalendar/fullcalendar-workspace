{
  "name": "@fullcalendar/theme-monarch-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./ui-default-palettes.css": "./src/ui-default-palettes.css",
    "./ui-default-palettes-vanilla.css": "./src/ui-default-palettes-vanilla.css",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:*",
    "@fullcalendar/adaptive": "workspace:*",
    "@fullcalendar/daygrid": "workspace:*",
    "@fullcalendar/interaction": "workspace:*",
    "@fullcalendar/list": "workspace:*",
    "@fullcalendar/multimonth": "workspace:*",
    "@fullcalendar/resource": "workspace:*",
    "@fullcalendar/resource-daygrid": "workspace:*",
    "@fullcalendar/resource-timeline": "workspace:*",
    "@fullcalendar/resource-timegrid": "workspace:*",
    "@fullcalendar/scrollgrid": "workspace:*",
    "@fullcalendar/timegrid": "workspace:*",
    "@fullcalendar/timeline": "workspace:*",
    "@fullcalendar/theme-common": "workspace:*",
    "typescript": "~5.7.2"
  }
}

{
  "name": "@fullcalendar/theme-monarch-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./ui-default-palettes.css": "./src/ui-default-palettes.css",
    "./ui-default-palettes-vanilla.css": "./src/ui-default-palettes-vanilla.css",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    }
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/react": "workspace:*",
    "temporal-polyfill": "^0.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/react": "workspace:*",
    "@fullcalendar/react-scheduler": "workspace:*",
    "@fullcalendar/theme-common": "workspace:*",
    "typescript": "~5.7.2",
    "temporal-polyfill": "^0.3.0"
  }
}

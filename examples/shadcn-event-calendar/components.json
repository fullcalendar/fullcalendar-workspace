{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/index.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@fullcalendar-breezy": "https://shadcn-registry.fullcalendar.io/breezy/{name}.json",
    "@fullcalendar-classic": "https://shadcn-registry.fullcalendar.io/classic/{name}.json",
    "@fullcalendar-forma": "https://shadcn-registry.fullcalendar.io/forma/{name}.json",
    "@fullcalendar-monarch": "https://shadcn-registry.fullcalendar.io/monarch/{name}.json",
    "@fullcalendar-pulse": "https://shadcn-registry.fullcalendar.io/pulse/{name}.json"
  }
}

    "@angular/router": "^22.0.2",
    "@fullcalendar/angular": "^7.0.0",
    "fullcalendar": "^7.0.0",
    "rxjs": "~7.8.0",
    "temporal-polyfill": "^1.0.1",
    "tslib": "^2.3.0"
  },
  "dependenciesMeta": {
    "@fullcalendar/angular": {
      "injected": true
    }
  },
  "devDependencies": {
    "@angular/build": "^22.0.2",

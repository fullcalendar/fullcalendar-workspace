{
  "name": "@full-ui/headless-grid",
  "version": "7.0.0-beta.7",
  "keywords": [
    "headless",
    "grid",
    "datagrid"
  ],
  "title": "Headless DataGrid Library",
  "description": "Headless datagrid library by the makers of FullCalendar",
  "devDependencies": {

{
  "name": "@fullcalendar/react-scheduler",
  "version": "7.0.0-rc.3",
  "title": "FullCalendar React Scheduler",
  "description": "FullCalendar React Scheduler package",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-rc.3",
    "@full-ui/headless-grid": "workspace:7.0.0-rc.3",
    "@fullcalendar/core": "workspace:7.0.0-rc.3"
  },
  "peerDependencies": {
    "@fullcalendar/react": "workspace:7.0.0-rc.3",
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@fullcalendar/react": "workspace:7.0.0-rc.3",
    "@fullcalendar-scripts/standard": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.4.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "temporal-polyfill": "^0.3.2",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "build": "pnpm run src:generate && standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean && pnpm run src:clean",
    "lint": "eslint .",
    "test": "vitest run",
    "test:dev": "vitest",
    "typecheck": "tsc -p tsconfig.tests.json",
    "src:generate": "./scripts/src-generate.sh",
    "src:clean": "rm -rf src"
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "src": "adaptive/index",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "src": "resource-daygrid/index",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "src": "resource-timegrid/index",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "src": "resource-timeline/index",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "src": "scrollgrid/index",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "src": "timeline/index",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

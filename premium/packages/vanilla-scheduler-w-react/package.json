{
  "name": "@fullcalendar/vanilla-scheduler-w-react",
  "private": true,
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@fullcalendar/core-types": "workspace:7.0.0-beta.6",
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "@fullcalendar/vanilla-w-react": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@fullcalendar/react": "workspace:7.0.0-beta.6",
    "@fullcalendar/react-scheduler": "workspace:7.0.0-beta.6",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "importRemaps": {
      "@fullcalendar/react": "@fullcalendar/vanilla-w-react",
      "@fullcalendar/react/public-api": "@fullcalendar/vanilla-w-react/public-api",
      "@fullcalendar/react/protected-api": "@fullcalendar/vanilla-w-react/protected-api",
      "@fullcalendar/react/protected-styles": "@fullcalendar/vanilla-w-react/protected-styles",
      "@fullcalendar/react/interaction": "@fullcalendar/vanilla-w-react/interaction",
      "@fullcalendar/react/daygrid": "@fullcalendar/vanilla-w-react/daygrid",
      "@fullcalendar/react/timegrid": "@fullcalendar/vanilla-w-react/timegrid",
      "@fullcalendar/react/list": "@fullcalendar/vanilla-w-react/list",
      "@fullcalendar/react/multimonth": "@fullcalendar/vanilla-w-react/multimonth"
    },
    "globalConfig": {
      "externalPkgs": [
        "@fullcalendar/vanilla-w-react",
        "react"
      ],
      "externalGlobals": {
        "@fullcalendar/vanilla-w-react": "FullCalendar",
        "@fullcalendar/vanilla-w-react/public-api": "FullCalendar",
        "@fullcalendar/vanilla-w-react/protected-api": "FullCalendar.ProtectedApi",
        "@fullcalendar/vanilla-w-react/protected-styles": "FullCalendar.ProtectedStyles",
        "@fullcalendar/vanilla-w-react/interaction": "FullCalendar.Interaction",
        "@fullcalendar/vanilla-w-react/daygrid": "FullCalendar.DayGrid",
        "@fullcalendar/vanilla-w-react/timegrid": "FullCalendar.TimeGrid",
        "@fullcalendar/vanilla-w-react/list": "FullCalendar.List",
        "@fullcalendar/vanilla-w-react/multimonth": "FullCalendar.MultiMonth",
        "react": "FullCalendar.Preact",
        "react/jsx-runtime": "FullCalendar.PreactJSXRuntime"
      }
    },
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./all.global": {
        "format": "global",
        "primary": true
      },
      "./adaptive": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/web-component-scheduler",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1"
  },
  "peerDependencies": {
    "@fullcalendar/web-component": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@fullcalendar/vanilla": "workspace:7.0.0-beta.6",
    "@fullcalendar/vanilla-scheduler": "workspace:7.0.0-beta.6"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "importRemaps": {
      "@fullcalendar/vanilla/public-api": "@fullcalendar/web-component",
      "@fullcalendar/vanilla/protected-api": "@fullcalendar/web-component/protected-api",
      "@fullcalendar/vanilla/protected-styles": "@fullcalendar/web-component/protected-styles",
      "@fullcalendar/vanilla/interaction": "@fullcalendar/web-component/interaction",
      "@fullcalendar/vanilla/daygrid": "@fullcalendar/web-component/daygrid",
      "@fullcalendar/vanilla/timegrid": "@fullcalendar/web-component/timegrid",
      "@fullcalendar/vanilla/list": "@fullcalendar/web-component/list",
      "@fullcalendar/vanilla/multimonth": "@fullcalendar/web-component/multimonth"
    },
    "globalConfig": {
      "externalPkgs": [
        "@fullcalendar/web-component",
        "preact"
      ],
      "externalGlobals": {
        "@fullcalendar/web-component": "FullCalendar",
        "@fullcalendar/web-component/protected-api": "FullCalendar.ProtectedApi",
        "@fullcalendar/web-component/protected-styles": "FullCalendar.ProtectedStyles",
        "@fullcalendar/web-component/interaction": "FullCalendar.Interaction",
        "@fullcalendar/web-component/daygrid": "FullCalendar.DayGrid",
        "@fullcalendar/web-component/timegrid": "FullCalendar.TimeGrid",
        "@fullcalendar/web-component/list": "FullCalendar.List",
        "@fullcalendar/web-component/multimonth": "FullCalendar.MultiMonth",
        "preact": "FullCalendar.Preact",
        "preact/compat": "FullCalendar.Preact",
        "preact/compat/client": "null",
        "preact/jsx-runtime": "FullCalendar.PreactJSXRuntime"
      }
    },
    "exports": {
      "./all": {
        "format": "module"
      },
      "./all.global": {
        "format": "global",
        "primary": true
      },
      "./adaptive": {
        "format": "module"
      },
      "./resource-daygrid": {
        "format": "module"
      },
      "./resource-timegrid": {
        "format": "module"
      },
      "./resource-timeline": {
        "format": "module"
      },
      "./scrollgrid": {
        "format": "module"
      },
      "./timeline": {
        "format": "module"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/web-component-scheduler",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "@fullcalendar/web-component": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@fullcalendar/vanilla": "workspace:7.0.0-beta.6",
    "@fullcalendar/vanilla-scheduler": "workspace:7.0.0-beta.6"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "moduleConfig": {
      "externalPkgs": [
        "@fullcalendar/preact"
      ],
      "externalRemaps": {
        "@fullcalendar/preact/public-api": "@fullcalendar/web-component/public-api",
        "@fullcalendar/preact/protected-api": "@fullcalendar/web-component/protected-api",
        "@fullcalendar/preact/protected-styles": "@fullcalendar/web-component/protected-styles",
        "@fullcalendar/preact/daygrid": "@fullcalendar/web-component/daygrid",
        "@fullcalendar/preact/timegrid": "@fullcalendar/web-component/timegrid"
      }
    },
    "globalConfig": {
      "externalPkgs": [
        "@fullcalendar/preact"
      ],
      "externalGlobals": {
        "@fullcalendar/preact/public-api": "FullCalendar.PublicApi",
        "@fullcalendar/preact/protected-api": "FullCalendar.ProtectedApi",
        "@fullcalendar/preact/protected-styles": "FullCalendar.ProtectedStyles",
        "@fullcalendar/preact/daygrid": "FullCalendar.DayGrid",
        "@fullcalendar/preact/timegrid": "FullCalendar.TimeGrid"
      }
    },
    "exports": {
      "./all": {
        "format": "module"
      },
      "./all.global": {
        "format": "global",
        "primary": true
      },
      "./adaptive": {
        "format": "module"
      },
      "./resource-daygrid": {
        "format": "module"
      },
      "./resource-timegrid": {
        "format": "module"
      },
      "./resource-timeline": {
        "format": "module"
      },
      "./scrollgrid": {
        "format": "module"
      },
      "./timeline": {
        "format": "module"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

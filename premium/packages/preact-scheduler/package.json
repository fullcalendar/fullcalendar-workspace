{
  "name": "@fullcalendar/preact-scheduler",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6",
    "@fullcalendar/core-types": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "@fullcalendar/preact": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1"
  },
  "devDependencies": {
    "@fullcalendar-scripts/standard": "workspace:*"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "importRemaps": {
      "react": "preact/compat",
      "react/jsx-runtime": "preact/jsx-runtime",
      "react-dom": "preact/compat",
      "react-dom/client": "preact/compat/client"
    },
    "exports": {
      "./all": {
        "format": "module"
      },
      "./adaptive": {
        "format": "module",
        "src": "adaptive/index"
      },
      "./resource-daygrid": {
        "format": "module",
        "src": "resource-daygrid/index"
      },
      "./resource-timegrid": {
        "format": "module",
        "src": "resource-timegrid/index"
      },
      "./resource-timeline": {
        "format": "module",
        "src": "resource-timeline/index"
      },
      "./scrollgrid": {
        "format": "module",
        "src": "scrollgrid/index"
      },
      "./timeline": {
        "format": "module",
        "src": "timeline/index"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/preact-scheduler",
  "version": "7.0.0-beta.8",
  "title": "FullCalendar Preact Scheduler",
  "description": "FullCalendar Preact Scheduler package",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.8",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.8",
    "@fullcalendar/core": "workspace:7.0.0-beta.8"
  },
  "peerDependencies": {
    "@fullcalendar/preact": "workspace:7.0.0-beta.8",
    "preact": "^10.29.0",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@fullcalendar/preact": "workspace:7.0.0-beta.8",
    "@fullcalendar-scripts/standard": "workspace:*",
    "preact": "^10.29.0",
    "temporal-polyfill": "^0.3.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "importRemaps": {
      "react": "preact/compat",
      "react/jsx-runtime": "preact/jsx-runtime",
      "react-dom": "preact/compat",
      "react-dom/client": "preact/compat/client"
    },
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "src": "adaptive/index",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "src": "resource-daygrid/index",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "src": "resource-timegrid/index",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "src": "resource-timeline/index",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "src": "scrollgrid/index",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "src": "timeline/index",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

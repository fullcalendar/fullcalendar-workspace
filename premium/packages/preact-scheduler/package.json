{
  "name": "@fullcalendar/preact-scheduler",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@fullcalendar/preact": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6",
    "globby": "^13.1.2",
    "handlebars": "^4.1.2",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "src": "adaptive/index"
      },
      "./resource-daygrid": {
        "format": "module",
        "src": "resource-daygrid/index"
      },
      "./resource-timegrid": {
        "format": "module",
        "src": "resource-timegrid/index"
      },
      "./resource-timeline": {
        "format": "module",
        "src": "resource-timeline/index"
      },
      "./scrollgrid": {
        "format": "module",
        "src": "scrollgrid/index"
      },
      "./timeline": {
        "format": "module",
        "src": "timeline/index"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

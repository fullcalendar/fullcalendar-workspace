{
  "name": "@fullcalendar/resource-daygrid",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Resource Day Grid Plugin",
  "description": "Display events on day/resource columns",
  "keywords": [
    "scheduler",
    "resource"
  ],
  "homepage": "https://fullcalendar.io/docs/resource-daygrid-view",
  "dependencies": {
    "@fullcalendar/daygrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/premium-common": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.ResourceDayGrid"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.ResourceDayGrid"
      },
      "./internal": {
        "module": true,
        "globalVar": "FullCalendar.ResourceDayGrid.Internal"
      }
    },
    "dependencyGlobalVars": {
      "preact": "",
      "preact/compat": "",
      "react": "",
      "react-dom": "",
      "react-dom/client": ""
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

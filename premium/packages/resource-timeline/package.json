{
  "name": "@fullcalendar/resource-timeline",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Resource Timeline Plugin",
  "description": "Display events and resources on a horizontal time axis",
  "keywords": [
    "scheduler",
    "resource",
    "timeline"
  ],
  "homepage": "https://fullcalendar.io/docs/timeline-view",
  "dependencies": {
    "@fullcalendar/premium-common": "workspace:7.0.0-beta.6",
    "@fullcalendar/scrollgrid": "workspace:7.0.0-beta.6",
    "@fullcalendar/timeline": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar/resource": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.ResourceTimeline"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.ResourceTimeline"
      },
      "./internal": {
        "module": true,
        "globalVar": "FullCalendar.ResourceTimeline.Internal"
      }
    },
    "dependencyGlobalVars": {
      "preact": "",
      "preact/compat": "",
      "react": "",
      "react-dom": "",
      "react-dom/client": ""
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

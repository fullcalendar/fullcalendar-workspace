{
  "name": "@fullcalendar/premium-common",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Premium Common",
  "description": "Utilities for FullCalendar's premium plugins",
  "peerDependencies": {
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*",
    "preact": "~10.23.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.PremiumCommon"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.PremiumCommon"
      }
    },
    "dependencyGlobalVars": {
      "preact": "",
      "preact/compat": "",
      "react": "",
      "react-dom": "",
      "react-dom/client": ""
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

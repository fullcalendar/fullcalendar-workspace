{
  "name": "@fullcalendar/vue3-scheduler",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Vue 3",
  "description": "FullCalendar Vue 3 Scheduler package",
  "dependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@full-ui/headless-calendar": "workspace:7.0.0-beta.6",
    "@full-ui/headless-grid": "workspace:7.0.0-beta.6",
    "preact": "~10.23.1"
  },
  "peerDependencies": {
    "@fullcalendar/vue3": "workspace:7.0.0-beta.6",
    "vue": "^3.0.11"
  },
  "devDependencies": {
    "@fullcalendar/vue3": "workspace:7.0.0-beta.6",
    "fullcalendar": "workspace:7.0.0-beta.6",
    "fullcalendar-scheduler": "workspace:7.0.0-beta.6",
    "vue": "^3.2.41"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "importRemaps": {
      "fullcalendar": "@fullcalendar/vue3",
      "fullcalendar/public-api": "@fullcalendar/vue3",
      "fullcalendar/protected-api": "@fullcalendar/vue3/protected-api",
      "fullcalendar/protected-styles": "@fullcalendar/vue3/protected-styles",
      "fullcalendar/interaction": "@fullcalendar/vue3/interaction",
      "fullcalendar/daygrid": "@fullcalendar/vue3/daygrid",
      "fullcalendar/timegrid": "@fullcalendar/vue3/timegrid",
      "fullcalendar/list": "@fullcalendar/vue3/list",
      "fullcalendar/multimonth": "@fullcalendar/vue3/multimonth"
    },
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

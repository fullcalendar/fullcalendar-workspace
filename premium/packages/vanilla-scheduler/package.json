{
  "name": "fullcalendar-scheduler",
  "version": "7.1.0-alpha.0",
  "title": "FullCalendar Scheduler (Vanilla JS)",
  "description": "FullCalendar Vanilla JS Scheduler package",
  "dependencies": {
    "@full-ui/headless-calendar": "workspace:7.1.0-alpha.0",
    "@full-ui/headless-grid": "workspace:7.1.0-alpha.0",
    "@fullcalendar/core": "workspace:7.1.0-alpha.0",
    "preact": "^10.29.0"
  },
  "peerDependencies": {
    "fullcalendar": "workspace:7.1.0-alpha.0",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.4",
    "@fullcalendar/preact": "workspace:7.1.0-alpha.0",
    "@fullcalendar/preact-scheduler": "workspace:7.1.0-alpha.0",
    "archiver": "^7.0.1",
    "globby": "^13.1.2",
    "temporal-polyfill": "^0.3.2"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "archive": "node ./scripts/archive.ts",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "importRemaps": {
      "@fullcalendar/preact": "fullcalendar",
      "@fullcalendar/preact/public-api": "fullcalendar/public-api",
      "@fullcalendar/preact/protected-api": "fullcalendar/protected-api",
      "@fullcalendar/preact/protected-styles": "fullcalendar/protected-styles",
      "@fullcalendar/preact/interaction": "fullcalendar/interaction",
      "@fullcalendar/preact/daygrid": "fullcalendar/daygrid",
      "@fullcalendar/preact/timegrid": "fullcalendar/timegrid",
      "@fullcalendar/preact/list": "fullcalendar/list",
      "@fullcalendar/preact/multimonth": "fullcalendar/multimonth"
    },
    "globalConfig": {
      "externalPkgs": [
        "fullcalendar",
        "preact"
      ],
      "externalGlobals": {
        "fullcalendar": "FullCalendar",
        "fullcalendar/public-api": "FullCalendar",
        "fullcalendar/protected-api": "FullCalendar.ProtectedApi",
        "fullcalendar/protected-styles": "FullCalendar.ProtectedStyles",
        "fullcalendar/interaction": "FullCalendar.Interaction",
        "fullcalendar/daygrid": "FullCalendar.DayGrid",
        "fullcalendar/timegrid": "FullCalendar.TimeGrid",
        "fullcalendar/list": "FullCalendar.List",
        "fullcalendar/multimonth": "FullCalendar.MultiMonth",
        "preact": "FullCalendar.Preact",
        "preact/compat": "FullCalendar.Preact",
        "preact/jsx-runtime": "FullCalendar.PreactJSXRuntime"
      }
    },
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./all": {
        "format": "module",
        "sideEffects": true
      },
      "./all.global": {
        "format": "global",
        "primary": true
      },
      "./adaptive": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

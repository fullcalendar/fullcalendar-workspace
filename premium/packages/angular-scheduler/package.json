{
  "name": "@fullcalendar/angular-scheduler",
  "version": "7.0.0",
  "title": "FullCalendar Angular",
  "description": "FullCalendar Angular Scheduler package",
  "peerDependencies": {
    "@fullcalendar/angular": "workspace:7.0.0",
    "fullcalendar": "workspace:7.0.0",
    "fullcalendar-scheduler": "workspace:7.0.0",
    "temporal-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.2.16",
    "@angular/cli": "^16.2.16",
    "@angular/common": "^20.3.25",
    "@angular/compiler": "^16.2.0",
    "@angular/compiler-cli": "^16.2.0",
    "@angular/core": "^16.2.0",
    "@angular/platform-browser": "^16.2.0",
    "@angular/platform-browser-dynamic": "^16.2.0",
    "@fullcalendar/angular": "workspace:7.0.0",
    "@types/jasmine": "~4.3.0",
    "fullcalendar": "workspace:7.0.0",
    "fullcalendar-scheduler": "workspace:7.0.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "rxjs": "~7.8.0",
    "temporal-polyfill": "^1.0.1",
    "typescript": "~5.1.3",
    "zone.js": "~0.13.0"
  },
  "scripts": {
    "ng": "ng",
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean && rm -rf .angular/cache",
    "lint": "eslint .",
    "test": "ng test lib --watch=false --browsers ChromeHeadless",
    "test:dev": "ng test lib"
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

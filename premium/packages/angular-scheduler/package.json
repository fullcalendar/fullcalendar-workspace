{
  "name": "@fullcalendar/angular-scheduler",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar Core",
  "description": "FullCalendar core package for rendering a calendar",
  "peerDependencies": {
    "@fullcalendar/angular": "workspace:7.0.0-beta.6",
    "@fullcalendar/vanilla": "workspace:7.0.0-beta.6",
    "@fullcalendar/vanilla-scheduler": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@fullcalendar/angular": "workspace:7.0.0-beta.6",
    "@fullcalendar/vanilla": "workspace:7.0.0-beta.6",
    "@fullcalendar/vanilla-scheduler": "workspace:7.0.0-beta.6"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

{
  "name": "@fullcalendar/angular-scheduler",
  "version": "7.0.0-beta.7",
  "title": "FullCalendar Angular",
  "description": "FullCalendar Angular Scheduler package",
  "peerDependencies": {
    "@fullcalendar/angular": "workspace:7.0.0-beta.7",
    "fullcalendar": "workspace:7.0.0-beta.7",
    "fullcalendar-scheduler": "workspace:7.0.0-beta.7",
    "temporal-polyfill": "^0.3.0"
  },
  "devDependencies": {
    "@fullcalendar/angular": "workspace:7.0.0-beta.7",
    "fullcalendar": "workspace:7.0.0-beta.7",
    "fullcalendar-scheduler": "workspace:7.0.0-beta.7",
    "temporal-polyfill": "^0.3.0"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "format": "module",
        "sideEffects": true
      },
      "./adaptive": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-daygrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timegrid": {
        "format": "module",
        "sideEffects": true
      },
      "./resource-timeline": {
        "format": "module",
        "sideEffects": true
      },
      "./scrollgrid": {
        "format": "module",
        "sideEffects": true
      },
      "./timeline": {
        "format": "module",
        "sideEffects": true
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}

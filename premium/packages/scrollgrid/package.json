{
  "name": "@fullcalendar/scrollgrid",
  "version": "7.0.0-beta.6",
  "title": "FullCalendar ScrollGrid Plugin",
  "description": "Tabular data chunked into scrollable panes",
  "dependencies": {
    "@fullcalendar/premium-common": "workspace:7.0.0-beta.6"
  },
  "peerDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6"
  },
  "devDependencies": {
    "@fullcalendar/core": "workspace:7.0.0-beta.6",
    "@fullcalendar-scripts/standard": "workspace:*"
  },
  "scripts": {
    "build": "standard-scripts pkg:build",
    "clean": "standard-scripts pkg:clean",
    "lint": "eslint ."
  },
  "type": "module",
  "buildConfig": {
    "exports": {
      ".": {
        "module": true,
        "globalVar": "FullCalendar.ScrollGrid"
      },
      "./global": {
        "iife": true,
        "globalVar": "FullCalendar.ScrollGrid"
      },
      "./internal": {
        "module": true,
        "globalVar": "FullCalendar.ScrollGrid.Internal"
      }
    }
  },
  "publishConfig": {
    "directory": "./dist",
    "linkDirectory": true
  }
}
